# ===================================================
# ROOT .env untuk Docker Compose
# Salin file ini menjadi .env (jangan commit .env!)
# ===================================================

# MySQL root password (untuk healthcheck internal)
MYSQL_ROOT_PASSWORD=ganti_dengan_password_kuat

# Database settings
DB_HOST=mysql
DB_PORT=3306
DB_USER=pawcare
DB_PASSWORD=ganti_dengan_password_kuat
DB_NAME=petshop_db

# Backend port
PORT=5000

# Frontend API URL (untuk build React di Docker)
VITE_API_URL=https://api-pawcare.rifkydevs.my.id
